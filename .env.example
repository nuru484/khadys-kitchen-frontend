# Canonical site URL — used for metadata (metadataBase, canonical, Open Graph),
# the sitemap, and robots. No trailing slash. Falls back to the production URL
# in src/lib/site.ts when unset.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Origin of the Khady's Kitchen API (no trailing slash, no /api/v1 — that's
# appended in src/redux/api-slice.ts). Required: src/lib/env.ts throws at load
# if it's missing, so a misconfigured build fails fast instead of calling
# `undefined/api/v1`. Matches the backend dev port (4050).
NEXT_PUBLIC_SERVER_URI=http://localhost:4050
