# Canonical site URL — used for metadata (metadataBase, canonical, Open Graph),
# the sitemap, and robots. No trailing slash. Falls back to the production URL,
# in src/lib/site.ts when unset.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Origin of the Khady's Kitchen API (no trailing slash, no /api/v1 — that's
# appended in src/redux/api-slice.ts). Required: src/lib/env.ts throws at load
# if it's missing, so a misconfigured build fails fast instead of calling
# `undefined/api/v1`. Matches the backend dev port (4050).
NEXT_PUBLIC_SERVER_URI=http://localhost:4050

# Cloudflare Turnstile site key for the public forms (checkout, application,
# contact). OPTIONAL: when unset the widget renders nothing and forms submit
# unblocked — the backend also skips verification when its TURNSTILE_SECRET_KEY
# is unset. Set both (this + the backend secret) to enforce the challenge.
# Test key: 1x00000000000000000000AA (see https://developers.cloudflare.com/turnstile/get-started/#test-keys)
# Test fail key: 2x00000000000000000000AB (see https://developers.cloudflare.com/turnstile/get-started/#test-keys)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Shared secret for POST /api/revalidate (must match the backend's REVALIDATE_SECRET)
REVALIDATE_SECRET=your_revalidate_secret
